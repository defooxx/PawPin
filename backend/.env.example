PORT=4000
DB_FILE=./data/pawpin.db
# Railway PostgreSQL private URLs do not require SSL. Set true for external providers that do.
DATABASE_SSL=false
JSON_LIMIT=10mb
MAX_IMAGE_BYTES=7340032
MAX_DOCUMENT_BYTES=10485760
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
UPLOAD_RATE_LIMIT_MAX=20
REPORT_RATE_LIMIT_MAX=10
DUPLICATE_HASH_DISTANCE=5
SUSPENSION_THRESHOLD=3
ENABLE_REPORT_LIST=false
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REPORTER_HASH_SECRET=your_long_random_secret
SHELTER_API_TOKEN=your_long_random_shelter_token
# REQUIRED — must be different from REPORTER_HASH_SECRET
AUTH_JWT_SECRET=your_long_random_auth_secret
AUTH_TOKEN_TTL=7d
AUTH_ONE_TIME_TOKEN_MINUTES=30
# Local testing only. Keep false in production and send tokens by email instead.
EXPOSE_AUTH_TOKENS=false
GOOGLE_CLIENT_ID=42042976343-vud0kj1nu9rbus6hi2mv7ithloeu77m3.apps.googleusercontent.com
# Option A: paste the full Firebase service account JSON into Railway as one variable.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: split the service account JSON into these three variables instead.
FIREBASE_PROJECT_ID=pawpin-fe504
FIREBASE_CLIENT_EMAIL=
# Keep the \n characters escaped when pasting into Railway.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
RESEND_API_KEY=
EMAIL_FROM=PawPin <onboarding@resend.dev>
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_strong_admin_password
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
